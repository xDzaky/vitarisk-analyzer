# ─── Vitarisk Backend Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Server
PORT=3000
NODE_ENV=development

# Flask ML Microservice URL
# Local: http://localhost:5001
# Production: https://your-ml-service.up.railway.app
FLASK_URL=http://localhost:5001

# Nearby hospital lookup cache TTL in milliseconds
HOSPITAL_CACHE_TTL_MS=300000

# Overpass API timeout in milliseconds
OVERPASS_TIMEOUT_MS=20000

# Google Sign-In (get from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change-this-to-random-secret
JWT_EXPIRES_IN=7d

# Development login - set true for testing without Google OAuth
ALLOW_DEV_LOGIN=false

# Allowed origins for CORS (comma-separated, no spaces)
# Development: http://localhost:5173,http://localhost:3000
# Production:  https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Chatbot AI Provider
# Choose one primary provider and fill only the keys you use.
# Recommended:
# - GROQ_API_KEY for the main chatbot model
# - TAVILY_API_KEY for optional web search / retrieval
# - OPENROUTER_API_KEY as an alternative LLM provider
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# Chatbot behavior
CHATBOT_PROVIDER=groq
CHATBOT_MODEL=llama-3.3-70b-versatile
CHATBOT_ENABLE_WEB_SEARCH=false
